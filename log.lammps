#code that disassociates first enzyme-substrate complex (folP-DHPP 6-8 -> 5+1)
fix bondc1 reactgrp bond/react     react comp1_rxn reactgrp 10 0.0 5.5 preComp1 postComp1 comp1.map     react triad_rxn reactgrp 10 0.0 5.5 preTriad postTriad triad.map  # turns 2+6-8 -> 3+5+9
dynamic group bond_react_MASTER_group defined
# tell bond/react how long to keep highlight spheres (in timesteps)
#fix bondb0 reactgrp bond/break 10 1 5.5

#fix_modify bondc1 fcolor yellow ftrans 0.5

#dump file for channeling analysis
compute flux reactgrp property/local btype batom1 batom2
dump bondinfo reactgrp local 100 bond_data.txt c_flux[1] c_flux[2] c_flux[3]

# unsure if adding break code here

#dump file for product yield
variable tstep equal step
thermo_style custom step ebond etotal temp f_bondc1[2]
timestep 25

restart 100000 sim1.1.restart sim1.2.restart #change parameter

# equilibration trajectory (for checking)
dump equi all dcd 500 preequi.$a.dcd
dump equi all dcd 500 preequi.233.dcd
dump_modify equi unwrap yes

#dump file for trajectory
dump dyn all dcd 1000 equi1.$a.dcd
dump dyn all dcd 1000 equi1.233.dcd
dump_modify dyn unwrap yes

# OPTIONAL: text trajectory for OVITO
dump ovito all custom 1000 traj.$a.dump id type mol x y z ix iy iz
dump ovito all custom 1000 traj.233.dump id type mol x y z ix iy iz
dump_modify ovito sort id

#another dump file for channeling analysis
dump dyn2 all custom 1000 atomtype.$a.dump id type x y z
dump dyn2 all custom 1000 atomtype.233.dump id type x y z

# ---------- short visualization test run ----------

